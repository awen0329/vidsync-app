# Copy this file to `.env.local` and fill in the values. `.env.local`
# is gitignored.
#
# To find your daemon's API key:
#   1. Start syncthing once on your machine.
#   2. Open ~/AppData/Local/Syncthing/config.xml (Windows)
#                or ~/.config/syncthing/config.xml (Linux/macOS).
#   3. Copy the value of the <apikey> element inside <gui>.
#
# Or read it directly from the running daemon at
# http://127.0.0.1:8384 — Settings → API key.

VITE_DAEMON_URL=http://127.0.0.1:8384
VITE_API_KEY=

# Clerk publishable key for the React SDK. Get it from the Clerk
# dashboard → API Keys → Publishable key. Starts with `pk_test_…` or
# `pk_live_…`.
VITE_CLERK_PUBLISHABLE_KEY=

# Base URL of the Vidsync control-plane backend. For local dev this is
# the address `cmd/server` listens on (default :8080).
#
# IMPORTANT for desktop builds (especially macOS): use https only.
# build/darwin/Info.plist sets NSAllowsArbitraryLoads=false, so WKWebView
# silently blocks plain-HTTP fetches to non-loopback hosts. A misconfigured
# http://… here makes /v1/me fail invisibly and the sidebar falls back to
# "Signed in" instead of the user's email. The production URL is
# https://server.thevidsync.com.
VITE_CLOUD_API_URL=http://localhost:8080
