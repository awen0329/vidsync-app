<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Entitlements for the MAC APP STORE (App Sandbox). This path is HARD for a
  Syncthing-based app and is NOT recommended as the first target — see
  STORE_PUBLISHING.md. Shipping on MAS requires, beyond these entitlements:
    * Replacing the GPL ffmpeg build with an LGPL one (GPL is incompatible
      with App Store terms — this is why VLC was pulled).
    * Re-working folder access around user-selected folders + security-scoped
      bookmarks (the sandbox forbids the "watch any path" model).
    * Signing braw-thumb/ffmpeg as bundled, sandbox-inheriting helper tools.
    * Login-item autostart via SMAppService (not a launchd plist).
  Kept here so the sandbox capability set is captured and ready when/if we
  do that work.
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.app-sandbox</key>
    <true/>
    <!-- Outbound: cloud control plane + connections to sync peers/relays. -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Inbound: the Syncthing engine listens for incoming peer connections. -->
    <key>com.apple.security.network.server</key>
    <true/>
    <!-- User explicitly picks the folders to sync. -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <!-- Persist access to those folders across launches. -->
    <key>com.apple.security.files.bookmarks.app-scope</key>
    <true/>
</dict>
</plist>
